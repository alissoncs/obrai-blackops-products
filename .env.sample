# Copy this file to .env and fill values.
# The script scripts/categorize_products.py auto-loads .env from repository root.

# Required for real classification runs (OpenAI)
OPENAI_API_KEY=

# Optional model tuning (GPT-4 mini family)
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=45

# Optional: proxy / Azure-compatible OpenAI base URL
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional API override (catalog taxonomy)
CATEGORIES_URL=https://obrai-app1-ifnsz.ondigitalocean.app/api/catalog/categories?displayMainMenu=true

# Optional defaults for shell usage
SUPPLIER=tigre
